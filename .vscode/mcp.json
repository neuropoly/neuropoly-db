{
  "servers": {
    // A2.2 — Jupyter MCP Server (project-scoped)
    // Connects to a running Jupyter server for real-time notebook interaction.
    // Start Jupyter first: jupyter lab --port 8888 --no-browser
    // Set JUPYTER_TOKEN if your server requires authentication.
    "jupyter": {
      "type": "stdio",
      "command": "/home/vscode/.local/bin/uvx",
      "args": ["jupyter-mcp-server"],
      "env": {
        "JUPYTER_BASE_URL": "http://localhost:8888",
        "JUPYTER_TOKEN": "${env:JUPYTER_TOKEN}"
      }
    }
  }
}
